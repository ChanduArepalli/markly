# ── Database ─────────────────────────────────────────────────────
POSTGRES_USER=markly
POSTGRES_PASSWORD=markly_secret
POSTGRES_DB=markly
DATABASE_URL=postgresql://markly:markly_secret@db:5432/markly

# ── Security ─────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change_me_generate_with_secrets_token_urlsafe_64
SECRET_KEY=change_me_generate_with_secrets_token_urlsafe_32

# ── Google OAuth 2.0 ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ── App ──────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Admin panel (/admin) ──────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# ── Cloudflare Tunnel ─────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=
